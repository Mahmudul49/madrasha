# Copy this file to `.env.local` for local dev, and set the same variable
# in the Vercel dashboard (Project → Settings → Environment Variables).
#
# Base URL of the backend API used by the admin dashboard and a few
# data-fetching pages (e.g. /carrier). If it is not set, those pages
# fall back to empty data so the build still succeeds.
NEXT_PUBLIC_BASE_URL=
